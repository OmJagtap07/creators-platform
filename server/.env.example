# Environment Variables — Creator's Platform Server
# Copy this file to .env and fill in your own values. Never commit the actual .env file.
#
# MONGO_URI: Use your Atlas/local URI here (with 'localhost' or Atlas hostname).
# When running inside Docker Compose, this value is OVERRIDDEN by docker-compose.yml
# to use the 'mongo' service hostname instead of 'localhost'.

PORT=5000
MONGO_URI=mongodb://username:password@localhost:27017/creator-platform?authSource=admin
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRE=7d
CLIENT_URL=http://localhost:5173

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
